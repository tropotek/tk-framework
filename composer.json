{
    "name": "ttek/tk-framework",
    "type": "library",
    "description": "Tk8 Lib: Tropotek Framework Library",
    "keywords":  [
        "Tk",
        "framework",
        "tropotek"
    ],
    "time": "2025-10-09",
    "license": "MIT",
    "authors":  [
         {
            "name": "Michael Mifsud",
            "homepage": "http://www.tropotek.com/"
        }
    ],
    "funding":  [
         {
            "type": "Paypal",
            "url": "https://www.paypal.me/tropotek"
        }
    ],
    "autoload":  {
